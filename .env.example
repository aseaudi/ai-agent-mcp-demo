# ============================================================
# Bitbucket MCP Agent — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Bitbucket Credentials ────────────────────────────────────
# Your Bitbucket username (email address for Cloud)
BITBUCKET_USERNAME=your_bitbucket_username

# App password: https://bitbucket.org/account/settings/app-passwords/
# Required permissions: Repositories (Read, Write)
BITBUCKET_APP_PASSWORD=your_bitbucket_app_password

# The workspace slug (bitbucket.org/{workspace}/...)
BITBUCKET_WORKSPACE=your_workspace_slug

# The repository slug (bitbucket.org/{workspace}/{repo}/...)
BITBUCKET_REPO=your_repository_slug

# ── MCP Server ───────────────────────────────────────────────
# Uses @nexus2520/bitbucket-mcp-server (Bitbucket Cloud + Server)
MCP_SERVER_COMMAND=npx
MCP_SERVER_ARGS=-y,@nexus2520/bitbucket-mcp-server
MCP_SERVER_CWD=

# For Bitbucket Server / Data Center, also set:
# BITBUCKET_BASE_URL=https://bitbucket.yourcompany.com

# ── Optional Atlassian MCP Server (Confluence / Jira) ─────────
# Uses uvx mcp-atlassian.
ATLASSIAN_MCP_SERVER_COMMAND=uvx
ATLASSIAN_MCP_SERVER_ARGS=mcp-atlassian
JIRA_URL=https://your-company.atlassian.net
JIRA_USERNAME=your.email@company.com
JIRA_API_TOKEN=your_api_token
CONFLUENCE_URL=https://your-company.atlassian.net/wiki
CONFLUENCE_USERNAME=your.email@company.com
CONFLUENCE_API_TOKEN=your_api_token

# ── Agent Behaviour ──────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-20250514

# Branch to read/write files on (used as "ref" in tool calls)
TARGET_BRANCH=main

# Commit author
GIT_AUTHOR_NAME=Bitbucket MCP Agent
GIT_AUTHOR_EMAIL=agent@example.com
